# Docker-based HIP compilation for Parboil LBM
# Uses ROCm Docker image - no local ROCm installation required

DOCKER_IMAGE = rocm/dev-ubuntu-24.04:7.2.4
GPU_TARGET = gfx942
SRC = parboil_lbm.cpp
# The GPU code object file generated by --save-temps
GPU_OBJ = parboil_lbm-hip-amdgcn-amd-amdhsa-$(GPU_TARGET).o
HSACO = parboil_lbm.hsaco
DISASM = parboil_lbm.disasm

# Run hipcc inside Docker container
# --platform linux/amd64 required for Apple Silicon Macs
DOCKER_RUN = docker run --rm --platform linux/amd64 -v $(PWD):/work -w /work $(DOCKER_IMAGE)

.PHONY: all clean clean-all regen-disasm

all: $(HSACO)

# Compile HIP source with --save-temps to get intermediate GPU object file.
#
# -ffast-math is required: without it, the AMDGPU backend lowers the
# `1.0f / fmaxf(rho, ...)` reciprocal to the IEEE-correct division sequence
# (v_div_scale_f32 / v_div_fmas_f32 / v_div_fixup_f32). On gfx942 the
# compiler emits v_div_scale_f32 as VOP3A opcode 514, which the MGPUSim
# CDNA3 functional emulator does not decode. -ffast-math lowers the
# reciprocal to a single v_rcp_f32 (a supported VOP1 instruction); the small
# precision difference stays well within the benchmark's 1e-3 tolerance.
$(HSACO): $(SRC)
	$(DOCKER_RUN) hipcc -ffast-math --save-temps -c --offload-arch=$(GPU_TARGET) $<
	cp $(GPU_OBJ) $(HSACO)

# Regenerate LLVM disassembly (requires Docker)
regen-disasm: $(HSACO)
	$(DOCKER_RUN) /opt/rocm/llvm/bin/llvm-objdump --disassemble --mcpu=$(GPU_TARGET) $(HSACO) > $(DISASM)
	@echo "Updated $(DISASM)"

clean:
	rm -f *.ll *.bc *.s *.o *.cui *.fatbin *.hipfb
	@echo "Note: $(HSACO) and $(DISASM) are preserved (checked into git)"

clean-all: clean
	rm -f $(HSACO) $(DISASM)
